#define BLYNK_TEMPLATE_NAME "DHT22"
#define BLYNK_AUTH_TOKEN "1jfE2Dsahemtthqeja_7bygMwhWFQk5x"

#include <Arduino.h> // Required for VS Code
#include <WiFi.h>
#include <WiFiClient.h>
#include <BlynkSimpleEsp32.h>
#include <LiquidCrystal.h>
#include "DHT.h"

// WiFi Credentials for Wokwi
char auth[] = BLYNK_AUTH_TOKEN;
char ssid[] = "Wokwi-GUEST";
char pass[] = "";

// Hardware Pins
#define DHTPIN 13
#define DHTTYPE DHT22
#define LED_PIN 25

// Initialize LCD (RS, E, D4, D5, D6, D7)
LiquidCrystal lcd(21, 19, 18, 5, 4, 2);
DHT dht(DHTPIN, DHTTYPE);
BlynkTimer timer;

// Global variables to store readings
float h, t;

// Function to read sensor and send to Blynk
void myTimerEvent() {
  h = dht.readHumidity();
  t = dht.readTemperature();

  if (isnan(h) || isnan(t)) {
    Serial.println(F("Failed to read from DHT sensor!"));
    return;
  }

  // 1. Send data to Blynk App
  Blynk.virtualWrite(V0, h); // V0 for Humidity
  Blynk.virtualWrite(V1, t); // V1 for Temperature

  // 2. Logic: If temp >= 50, turn on LED on Pin 25
  if (t >= 50.00) {
    digitalWrite(LED_PIN, HIGH);
  } else {
    digitalWrite(LED_PIN, LOW);
  }

  // 3. Update Serial Monitor
  Serial.print(F("Humidity: "));
  Serial.print(h);
  Serial.print(F("%  Temperature: "));
  Serial.print(t);
  Serial.println(F("°C"));

  // 4. Update LCD Screen
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Humid: ");
  lcd.print(h, 1);
  lcd.print("%");
  
  lcd.setCursor(0, 1);
  lcd.print("Temp:  ");
  lcd.print(t, 1);
  lcd.print("C");
}

void setup() {
  Serial.begin(115200);
  
  // Set LED pin
  pinMode(LED_PIN, OUTPUT);

  // Initialize LCD and Sensor
  lcd.begin(16, 2);
  dht.begin();

  // Connect to Blynk
  Blynk.begin(auth, ssid, pass);

  // Setup timer to run every 2 seconds
  timer.setInterval(2000L, myTimerEvent);
}

void loop() {
  Blynk.run();
  timer.run(); // All the sensor work is done inside myTimerEvent via this timer
}











