#include <WiFi.h>
#include <HTTPClient.h>
#include "DHT.h"
#include <Wire.h> 
#include <LiquidCrystal_I2C.h>

const char* ssid = "Wokwi-GUEST";
const char* password = "";

String apiKey = "VLEIWMHH82MLCBD";
const char* server = "api.thingspeak.com";

#define DHTPIN 4        
#define DHTTYPE DHT22    
DHT dht(DHTPIN, DHTTYPE);

LiquidCrystal_I2C lcd(0x27, 16, 2);

void setup() {
  Serial.begin(115200);
  dht.begin();
  
  lcd.init();
  lcd.backlight();
  
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
  }
}

void loop() {
  delay(15000);

  float t = dht.readTemperature();
  float h = dht.readHumidity();

  if (isnan(t) || isnan(h)) {
    lcd.clear();
    lcd.print("Sensor Error");
    return;
  }

  // Update LCD with both values
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("T: ");
  lcd.print(t);
  lcd.print("C");
  
  lcd.setCursor(0, 1);
  lcd.print("H: ");
  lcd.print(h);
  lcd.print("%");

  // Send Data to ThingSpeak (Field 1: Temp, Field 2: Humidity)
  if (WiFi.status() == WL_CONNECTED) {
    HTTPClient http;
    String url = "http://" + String(server) + "/update?api_key=" + apiKey + "&field1=" + String(t) + "&field2=" + String(h);
   
    http.begin(url);
    http.GET();
    http.end();
  }
}
